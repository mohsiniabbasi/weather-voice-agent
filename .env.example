# Copy this file to ".env" (or set these in Vercel > Project > Settings > Environment Variables).
# Everything here is OPTIONAL for a first test — the weather lookup works with
# no keys at all. Add the notification keys when you want the "bring a coat"
# text/email to actually send.

# --- SMS (primary notification channel) ---
# From your Twilio trial account: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # your Twilio trial number, e.g. +14155551234

# --- Email (fallback if SMS fails / is blocked) ---
# The brief allows simulating the SMS with email. Resend free tier works well.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev   # or a verified sender on your domain

# --- Who receives the reminder in the demo ---
# For a Twilio TRIAL account this MUST be a number you've verified in Twilio.
DEFAULT_SMS_TO=           # e.g. +447700900000
DEFAULT_EMAIL_TO=         # e.g. you@example.com

# --- Shared store for idempotency / call log / DLQ (optional but recommended) ---
# Free serverless Redis from https://upstash.com — needed for idempotency to
# work for real across serverless invocations. Without it the app falls back
# to in-memory (fine for a quick local demo, not for production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
